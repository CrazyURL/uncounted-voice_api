# WhisperX 모델 설정
MODEL_SIZE=large-v3
DEVICE=cuda
COMPUTE_TYPE=float16
LANGUAGE=ko
BATCH_SIZE=4

# HuggingFace 토큰 (화자분리용)
HF_TOKEN=hf_your_token_here

# 화자분리 옵션 (Phase 2: Option D)
VOICE_DIARIZATION_FORCE_TWO_SPEAKERS=false
VOICE_DIARIZATION_FORCE_TWO_SPEAKERS_ENDPOINTS=call_recording

# 파일 경로
TEMP_DIR=/dev/shm/stt-temp
RESULTS_DIR=/dev/shm/stt-results

# 업로드 제한 (bytes)
MAX_UPLOAD_SIZE=104857600

# Phase 4: WeSpeaker 화자 임베딩 (speaker_embedding.py)
# VOICE_DIARIZATION_WESPEAKER_MODEL_PATH: ONNX 모델 파일 경로
#   - 다운로드: ./scripts/download_wespeaker.sh
#   - 기본 경로: $HOME/.cache/uncounted/wespeaker/wespeaker_resnet34lm.onnx
#   - 미설정 시: 임베딩 추출 불가 (EmbeddingUnavailable 반환)
VOICE_DIARIZATION_WESPEAKER_MODEL_PATH=

# VOICE_DIARIZATION_EMBEDDING_PROVIDER: ONNX 실행 프로바이더
#   - "cpu": CPU 전용 (기본값)
#   - "cuda": CUDA 우선, CPU 폴백 (NVIDIA GPU 필요)
VOICE_DIARIZATION_EMBEDDING_PROVIDER=cpu

# VOICE_DIARIZATION_ONNX_INTRA_OP_THREADS: ONNX CPU 스레드 수 (기본값: 2)
#   - CPU 병렬성 제어. GPU 사용 시 무시됨.
VOICE_DIARIZATION_ONNX_INTRA_OP_THREADS=2

# Phase 7: WeSpeaker 화자 재클러스터링 (speaker_recluster.py)
# VOICE_DIARIZATION_WESPEAKER_RECLUSTER: 재클러스터링 활성화 여부
#   - "true" / "false" (기본값: false)
#   - 현재 임베딩 모델 필수. 미설정 시 Hook 미실행 (byte-equivalent)
VOICE_DIARIZATION_WESPEAKER_RECLUSTER=false

# VOICE_DIARIZATION_WESPEAKER_RECLUSTER_ENDPOINTS: 재클러스터링 활성 엔드포인트
#   - 쉼표 분리 목록 (기본값: call_recording)
#   - 예: "call_recording,voicemail"
#   - 현재 모드가 목록에 없으면 Hook 미실행 (byte-equivalent)
VOICE_DIARIZATION_WESPEAKER_RECLUSTER_ENDPOINTS=call_recording

# VOICE_DIARIZATION_RECLUSTER_CONFIDENCE_THRESHOLD: 클러스터 신뢰도 임계값
#   - 0.0 ~ 1.0 (기본값: 0.15)
#   - 이 값 이상의 신뢰도 클러스터만 재라벨링 (intra/inter cosine 마진)
VOICE_DIARIZATION_RECLUSTER_CONFIDENCE_THRESHOLD=0.15

# VOICE_DIARIZATION_RECLUSTER_MIN_WINDOW_SEC: 최소 윈도우 길이 (초)
#   - 임베딩 추출 윈도우의 최소 길이 (기본값: 1.0)
VOICE_DIARIZATION_RECLUSTER_MIN_WINDOW_SEC=1.0

# VOICE_DIARIZATION_RECLUSTER_MAX_WINDOW_SEC: 최대 윈도우 길이 (초)
#   - 임베딩 추출 윈도우의 최대 길이 (기본값: 4.0)
#   - MAX > MIN 제약 필수. 위반 시 ReclusterConfigError 발생
VOICE_DIARIZATION_RECLUSTER_MAX_WINDOW_SEC=4.0
